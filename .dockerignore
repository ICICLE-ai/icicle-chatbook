# Keep the build context small and avoid leaking anything sensitive.

# Git
.git/
.gitignore

# Local virtual env (rebuilt inside the image)
.venv/
venv/
env/

# Secrets / env files (TAPIS_TOKEN etc.) — never bake into an image
.env
.env.*
!.env.example

# Python caches
__pycache__/
*.py[cod]
*$py.class
*.so

# marimo session cache
__marimo__/
.marimo/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build / packaging artifacts
dist/
build/
*.egg-info/
*.egg

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Docs / CI not needed at runtime
.github/
*.md
LICENSE

# Docker files themselves
Dockerfile
.dockerignore
